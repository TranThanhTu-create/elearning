# =====================================================
# EduVietPro — Environment Variables
# Sao chép file này thành .env và điền thông tin thật
# =====================================================

# --- App ---
APP_NAME="EduVietPro"
APP_ENV=development        # development | production
SECRET_KEY=your-secret-key-at-least-32-chars
DEBUG=true

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/eduvietpro
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@host:5432/eduvietpro

# --- Redis (Upstash) ---
REDIS_URL=redis://default:password@host:6379

# --- JWT ---
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 ngày
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- SePay ---
SEPAY_API_KEY=your-sepay-api-key
SEPAY_WEBHOOK_SECRET=your-sepay-webhook-secret
BANK_ACCOUNT_NUMBER=1234567890
BANK_NAME=Vietcombank
BANK_ACCOUNT_NAME=NGUYEN ANH TUAN
ORDER_EXPIRE_MINUTES=30

# --- Resend (Email) ---
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=hello@eduvietpro.vn
EMAIL_FROM_NAME=EduVietPro

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=eduvietpro
R2_PUBLIC_URL=https://cdn.eduvietpro.vn

# --- Google Sheets (Leads) ---
GOOGLE_SERVICE_ACCOUNT_JSON=./google-service-account.json
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_SHEET_NAME=Leads

# --- Frontend ---
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://eduvietpro.vn

# --- Timezone ---
TZ=Asia/Ho_Chi_Minh
